{
  "name": "sku-label-maker",
  "version": "0.2.0",
  "private": true,
  "description": "A PWA-enabled React label maker for product labels with PDF generation and GitHub Pages deployment.",
  "keywords": [
    "label",
    "PDF",
    "PWA",
    "react",
    "vite",
    "sku",
    "pdf-lib"
  ],
  "author": "jewel998",
  "license": "MIT",
  "type": "module",
  "homepage": "https://jewel998.github.io/sku",
  "repository": {
    "type": "git",
    "url": "https://github.com/jewel998/sku.git"
  },
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "pnpm run preview",
    "serve": "http-server dist -c-1 -p 3000",
    "analyze": "vite-bundle-visualizer",
    "clean": "rm -rf dist node_modules .turbo .next coverage pnpm-lock.yaml",
    "clean:dist": "rm -rf dist",
    "audit": "pnpm audit --fix",
    "audit:prod": "pnpm audit --prod",
    "ci": "pnpm install --frozen-lockfile && pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
    "ci:test": "pnpm run typecheck && pnpm run lint && pnpm run test",
    "lint": "eslint . --config .eslintrc.cjs --ext .ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --config .eslintrc.cjs --ext .ts,.tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "prepare": "husky install",
    "deploy": "pnpm run build",
    "prebuild": "pnpm run clean:dist && pnpm run typecheck",
    "postbuild": "pnpm run analyze",
    "prepack": "pnpm run ci"
  },
  "dependencies": {
    "firebase": "^12.12.1",
    "fontkit": "^2.0.4",
    "lodash-es": "^4.17.21",
    "lucide-react": "^1.8.0",
    "pdf-lib": "^1.17.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/fontkit": "^2.0.9",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.0.1",
    "@typescript-eslint/parser": "^8.0.1",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-react": "^7.35.0",
    "eslint-plugin-react-hooks": "^4.6.2",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "jsdom": "^24.1.0",
    "lint-staged": "^15.2.7",
    "postcss": "^8.4.35",
    "prettier": "^3.3.2",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.6.0",
    "vite": "^5.4.2",
    "vite-bundle-visualizer": "^1.1.1",
    "vite-plugin-pwa": "^0.20.1",
    "vitest": "^1.6.0"
  }
}
